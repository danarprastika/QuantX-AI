{
  "name": "@quantx/web",
  "version": "1.0.0",
  "description": "QuantX AI Frontend Web Application",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:api-client": "eslint src/application/api --ext .ts,.tsx --rule 'api-client'",
    "lint:cache-keys": "eslint src/shared/cache --ext .ts,.tsx --rule 'cache-keys'",
    "lint:flags": "eslint src --ext .ts,.tsx --rule 'flag-naming'",
    "lint:i18n": "eslint src --ext .ts,.tsx --rule 'i18n-strings'",
    "type-check": "tsc --noEmit",
    "openapi:generate": "openapi-typescript docs/api/openapi.yaml --output src/shared/api/types.ts",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":80,\"functions\":80,\"lines\":80,\"statements\":80}}'",
    "test:api-errors": "jest --config=test/unit/jest.api-errors.config.js",
    "test:rate-limits": "jest --config=test/unit/jest.rate-limits.config.js",
    "test:logging-format": "jest --config=test/unit/jest.logging-format.config.js",
    "test:metrics-emission": "jest --config=test/unit/jest.metrics-emission.config.js",
    "test:web-vitals": "jest --config=test/unit/jest.web-vitals.config.js",
    "test:error-display": "jest --config=test/unit/jest.error-display.config.js",
    "test:correlation-flow": "jest --config=test/unit/jest.correlation-flow.config.js",
    "test:validation-errors": "jest --config=test/unit/jest.validation-errors.config.js",
    "test:cache-invalidation": "jest --config=test/unit/jest.cache-invalidation.config.js",
    "test:offline-cache": "jest --config=test/unit/jest.offline-cache.config.js",
    "test:flag-targeting": "jest --config=test/unit/jest.flag-targeting.config.js",
    "test:sharia-flags": "jest --config=test/unit/jest.sharia-flags.config.js",
    "test:flag-fallback": "jest --config=test/unit/jest.flag-fallback.config.js",
    "test:locale-detection": "jest --config=test/unit/jest.locale-detection.config.js",
    "test:rtl-layout": "jest --config=test/unit/jest.rtl-layout.config.js",
    "test:i18n-fallback": "jest --config=test/unit/jest.i18n-fallback.config.js",
    "check:error-boundaries": "node scripts/check-error-boundaries.js",
    "check:cache-ttl": "node scripts/check-cache-ttl.js",
    "check:externalized-strings": "node scripts/check-externalized-strings.js",
    "check:lazy-loading": "node scripts/check-lazy-loading.js",
    "metrics:web-vitals": "lighthouse --output=json --output-path=./reports/web-vitals.json",
    "metrics:bundle-size": "webpack-bundle-analyzer dist/.next/static/chunks",
    "trace:coverage": "node scripts/trace-coverage.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.0.0",
    "@opentelemetry/sdk-browser": "^0.0.0",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/jest": "^29.0.0",
    "@openapitools/openapi-generator-cli": "^2.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-jsx-a11y": "^6.0.0",
    "jest": "^29.0.0",
    "typescript": "^5.0.0",
    "ts-jest": "^29.0.0",
    "lighthouse": "^12.0.0",
    "axe-core": "^4.0.0",
    "playwright": "^1.0.0"
  }
}