{
  "name": "@quantx/platform",
  "version": "1.0.0",
  "description": "QuantX AI Modular Monolith Backend",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "lint:api-naming": "eslint src/presentation/controllers --ext .ts --rule 'api-naming'",
    "lint:db-naming": "eslint prisma --ext .ts,.prisma --rule 'db-naming'",
    "lint:event-naming": "eslint src/domain --ext .ts --rule 'event-naming'",
    "lint:test-naming": "eslint test --ext .ts --rule 'test-naming'",
    "lint:cache-keys": "eslint src/infrastructure/cache --ext .ts --rule 'cache-keys'",
    "lint:flags": "eslint src --ext .ts --rule 'flag-naming'",
    "test": "jest",
    "test:coverage": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":80,\"functions\":80,\"lines\":80,\"statements\":80}}'",
    "test:contract": "jest --config=test/contract/jest.config.js",
    "api:validate-spec": "swagger-cli validate docs/api/openapi.yaml",
    "check:lineage": "node scripts/check-lineage.js",
    "check:uuid-format": "node scripts/check-uuid-format.js",
    "check:architecture": "node scripts/check-architecture.js",
    "check:cycles": "madge --circular src/",
    "check:repository-layers": "node scripts/check-repository-layers.js",
    "check:correlation-ids": "node scripts/check-correlation-ids.js",
    "check:cache-ttl": "node scripts/check-cache-ttl.js",
    "check:flag-audit": "node scripts/check-flag-audit.js",
    "check:backup-schedule": "node scripts/check-backup-schedule.js",
    "check:rto-rpo": "node scripts/check-rto-rpo.js",
    "check:restore-drills": "node scripts/check-restore-drills.js",
    "metrics:cache-ratio": "node scripts/metrics-cache-ratio.js",
    "trace:coverage": "node scripts/trace-coverage.js",
    "lint:exceptions": "eslint src/shared/kernel/exceptions --ext .ts --rule 'exception-hierarchy'",
    "lint:dependencies": "eslint src/ --ext .ts --rule 'dependency-direction'",
    "lint:aggregate-rules": "eslint src/domain --ext .ts --rule 'aggregate-rules'",
    "lint:business-rules": "eslint src --ext .ts --rule 'no-hardcoded-business-rules'",
    "lint:ai-naming": "eslint src --ext .ts --rule 'naming-convention'",
    "check:provenance": "node scripts/check-provenance.js",
    "test:error-envelope": "jest --config=test/unit/jest.error-envelope.config.js",
    "test:event-envelope": "jest --config=test/unit/jest.event-envelope.config.js",
    "test:event-idempotence": "jest --config=test/unit/jest.event-idempotence.config.js",
    "test:invariants": "jest --config=test/unit/jest.invariants.config.js",
    "test:flag-targeting": "jest --config=test/unit/jest.flag-targeting.config.js",
    "test:logging-format": "jest --config=test/unit/jest.logging-format.config.js",
    "test:metrics-presence": "jest --config=test/unit/jest.metrics-presence.config.js",
    "prisma": "prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@prisma/client": "^5.0.0",
    "prisma": "^5.0.0",
    "ioredis": "^5.0.0",
    "bullmq": "^4.0.0",
    "reflect-metadata": "^0.1.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "@types/swagger": "^0.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-import": "^2.0.0",
    "jest": "^29.0.0",
    "supertest": "^6.0.0",
    "swagger-cli": "^4.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "madge": "^5.0.0"
  }
}