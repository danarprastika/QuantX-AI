# QuantX AI Environment Configuration Template
# Copy this file to .env and fill in the values for your environment

# =============================================================================
# Core Configuration
# =============================================================================
QUANTX_ENV=development
QUANTX_SERVICE_NAME=quantx-api
QUANTX_LOG_LEVEL=INFO
QUANTX_DEBUG=true

# =============================================================================
# Database Configuration
# =============================================================================
QUANTX_DATABASE_URL=postgresql+asyncpg://quantx:quantx@localhost:5432/quantx_db
QUANTX_DATABASE_ECHO=false
QUANTX_DATABASE_POOL_SIZE=20
QUANTX_DATABASE_MAX_OVERFLOW=10

# =============================================================================
# Redis Configuration
# =============================================================================
QUANTX_REDIS_URL=redis://:quantx@localhost:6379/0
QUANTX_REDIS_MAX_CONNECTIONS=50

# =============================================================================
# Celery Configuration
# =============================================================================
QUANTX_WORKER_BROKER_URL=redis://:quantx@localhost:6379/1
QUANTX_WORKER_RESULT_BACKEND=redis://:quantx@localhost:6379/2
QUANTX_WORKER_TASK_SERIALIZER=json
QUANTX_WORKER_RESULT_SERIALIZER=json
QUANTX_WORKER_ACCEPT_CONTENT=json
QUANTX_WORKER_TIMEZONE=UTC
QUANTX_WORKER_ENABLE_UTC=true

# =============================================================================
# OpenTelemetry Configuration
# =============================================================================
QUANTX_OTEL_SERVICE_NAME=quantx-api
QUANTX_OTEL_SERVICE_VERSION=0.1.0
QUANTX_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# Telegram Bot Configuration
# =============================================================================
QUANTX_BOT_TOKEN=your_bot_token_here
QUANTX_BOT_ADMIN_IDS=123456789,987654321
QUANTX_BOT_LOG_LEVEL=INFO

# =============================================================================
# API Configuration
# =============================================================================
QUANTX_API_HOST=0.0.0.0
QUANTX_API_PORT=8000
QUANTX_API_WORKERS=4

# =============================================================================
# Security Configuration
# =============================================================================
QUANTX_SECRET_KEY=change-me-in-production-use-a-strong-secret-key
QUANTX_ALLOWED_HOSTS=localhost,127.0.0.1
QUANTX_CORS_ORIGINS=["http://localhost:3000"]

# =============================================================================
# Feature Flags
# =============================================================================
QUANTX_FEATURE_NEW_PREDICTOR=false
QUANTX_FEATURE_BACKTESTING=true
QUANTX_FEATURE_RISK_CONTROLS=true
